{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Claude Inspector",
  "version": "0.1.0",
  "identifier": "com.claude-inspector.app",
  "build": {
    "frontendDist": "../dist/inspector/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npx nx serve inspector",
    "beforeBuildCommand": "npx nx build inspector --configuration=production"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Inspector",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": null
    }
  }
}
